# Copy to `.env` and adjust. Variables consumed at runtime by app.py, db/ layer,
# Alembic and the test harness. Do not commit `.env`.

# --- Flask ---------------------------------------------------------------
# Generar con: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-secrets-token-hex-32
FLASK_DEBUG=0
# Generar con: python -c "import secrets;print(secrets.token_urlsafe(32))"
BOT_API_TOKEN=change-me-generate-with-secrets-token-urlsafe-32

# --- Seed inicial de usuarios (solo se aplica si la tabla users está vacía) ---
# Si no se definen, init_db saltará el seed e imprime instrucciones.
SEED_ANA_PASSWORD=
SEED_OLI_PASSWORD=

# --- Legacy SQLite (still used until SPEC-002c cutover) ------------------
FASSA_DB_PATH=./fassa_ops.db

# --- Postgres (SPEC-002a onwards) ----------------------------------------
# Local dev container (see docker-compose.yml, service `postgres`).
# Host port is 5434 (not 5432) to avoid collision with Homebrew Postgres.
DATABASE_URL=postgresql+psycopg://arias:arias@localhost:5434/arias_dev

# Local test container (see docker-compose.yml, service `postgres-test`).
TEST_DATABASE_URL=postgresql+psycopg://arias:arias@localhost:5433/arias_test

# --- Render (prod cutover) -----------------------------------------------
# Obtenida de Render Dashboard → managed Postgres → Connection Info.
# RENDER_DATABASE_URL=postgresql+psycopg://user:pass@host.render.com/arias_prod
